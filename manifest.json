{
  "manifest_version": 3,
  "name": "Tabs Home",
  "version": "1.0",
  "description": "Chrome tabs collection",
  "icons": {
    "16": "assets/icons/favicon-16x16.png",
    "32": "assets/icons/favicon-32x32.png",
    "48": "assets/icons/favicon-32x32.png",
    "128": "assets/icons/android-chrome-192x192.png"
  },
  "action": {
    "default_title": "Tabs Home",
    "default_icon": {
      "16": "assets/icons/favicon-16x16.png",
      "32": "assets/icons/favicon-32x32.png",
      "48": "assets/icons/favicon-32x32.png",
      "128": "assets/icons/android-chrome-192x192.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "permissions": ["storage", "activeTab", "tabs", "sidePanel"],
  "side_panel": {
    "default_path": "html/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/inject.js"],
      "match_about_blank": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["html/sidepanel.html", "src/content.js", "dist/style.css", "assets/icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
